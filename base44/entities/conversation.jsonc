// Conversation: a private thread between two subjects in the Rookery.
//
// There is exactly one per pair, keyed by their two subject ids sorted so
// initiator does not matter (a = the smaller id, b = the larger). Its status
// captures the whole rank-gated hook:
//   pending - one side reached across a rank line and the other has not yet
//             answered (a peasant's Audience request, or a noble's Summons).
//   open    - both may now speak freely, unlocked the moment the non-initiator
//             sent their first message.
//
// blocked_by holds the subject id of whoever blocked this thread (either side,
// any rank relationship). While set, NEITHER party may send. hidden_by holds
// whoever has removed this thread from their own inbox; it is per-viewer, the
// other person's copy is untouched, and a new message clears it so a hidden
// thread reappears the moment there is something new in it.
//
// Only the server writes these; clients read only the conversations they are in.
{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "a_id": { "type": "string" },
    "a_email": { "type": "string" },
    "a_handle": { "type": "string" },
    "b_id": { "type": "string" },
    "b_email": { "type": "string" },
    "b_handle": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "open"], "default": "pending" },
    "initiator_id": { "type": "string" },
    "last_message_at": { "type": "string", "format": "date-time" },
    "last_preview": { "type": "string" },
    "last_sender_id": { "type": "string" },
    "blocked_by": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Subject id(s) who have blocked this thread. Non-empty means neither side may send."
    },
    "hidden_by": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Subject id(s) who removed this thread from their own inbox. Per-viewer; cleared by a new message."
    }
  },
  "required": ["a_id", "b_id"],
  "rls": {
    "create": { "user_condition": { "role": "admin" } },
    "read": {
      "$or": [
        { "data.a_email": "{{user.email}}" },
        { "data.b_email": "{{user.email}}" }
      ]
    },
    "update": { "user_condition": { "role": "admin" } },
    "delete": false
  }
}
